# Core app settings
MODE=development
PROJECT_NAME=My FastAPI App
API_VERSION=v1

# Database (Postgres)
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=app
DATABASE_CELERY_NAME=celery_schedule_jobs

# Async URIs (optional; will be assembled from above if empty)
ASYNC_DATABASE_URI=
SYNC_CELERY_DATABASE_URI=
SYNC_CELERY_BEAT_DATABASE_URI=
ASYNC_CELERY_BEAT_DATABASE_URI=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# OpenAI/Azure OpenAI
OPENAI_API_KEY=
OPENAI_API_VERSION=2024-07-01-preview
AZURE_OPENAI_ENDPOINT=

# First superuser (bootstrap)
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=change-me

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_URL=http://127.0.0.1:9000
MINIO_BUCKET=files
# Optional internal URL if running in docker-compose
MINIO_INTERNAL_URL=http://minio:9000

# Milvus (optional)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DB=
MILVUS_TLS=false

# App security
# For production, set strong random values and NEVER commit real keys
SECRET_KEY=please-set-in-prod
ENCRYPT_KEY=please-set-in-prod

# CORS (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Other
WHEATER_URL=https://example.com/weather

# Tool system
TOOL_AUTO_SCAN_ON_START=false
TOOL_WATCHER_ENABLE=false

# Optional override .env path
# ENV_FILE=.env